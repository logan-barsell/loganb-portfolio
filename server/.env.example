NODE_ENV=development
HOST=127.0.0.1
PORT=3001

DATABASE_PATH=./data/inquiries.sqlite
UPLOAD_PATH=./data/uploads

RESEND_API_KEY=re_your_private_key
RESEND_FROM="Logan Barsell Web Services <website@mail.loganbarsell.com>"
INQUIRY_NOTIFY_TO=contact@loganbarsell.com

# Set to 1 behind nginx so rate limiting sees the real client IP
TRUST_PROXY=0

# Admin portal (required in production). Generate hash with: npm run hash-password
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=scrypt$16384$8$1$replace_with_npm_run_hash_password
ADMIN_SESSION_SECRET=replace_with_long_random_string_at_least_32_chars
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_SESSION_COOKIE_NAME=lb_admin_session
ALLOWED_ORIGIN=http://localhost:3000
